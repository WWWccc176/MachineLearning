# ========================
# Rust / Cargo
# ========================
# 忽略编译产物
/target/
**/target/
**/*.rs.bk

# 忽略 Cargo 锁文件 (可选：如果是通过库，通常提交；如果是纯本地实验，可以忽略)
# Cargo.lock

# ========================
# Python
# ========================
# 字节码编译文件
__pycache__/
*.py[cod]
*$py.class

# C 扩展
*.so

# ========================
# Python 虚拟环境 (关键)
# ========================
# 匹配常见的虚拟环境命名习惯
.venv
.venv/
venv/
ENV/
env/

